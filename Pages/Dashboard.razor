@page "/dashboard"
@using IntuneMonitor.Models
@using IntuneMonitor.Shared
@using Microsoft.AspNetCore.SignalR.Client
@attribute [Authorize]
@inject NavigationManager Nav

<SubscriptionGate>

<h2>Intune Enrollment Monitor</h2>

@if (devices is null)
{
    <p>Connecting to monitor...</p>
}
else
{
    <SummaryCards Devices="devices" />

    <table class="enrollment-table">
        <thead>
            <tr>
                <th>Device</th>
                <th>User</th>
                <th>Enrolled</th>
                <th>Last Sync</th>
                <th>Apps</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var d in devices)
        {
            <tr>
                <td>@d.DeviceName</td>
                <td>@d.UserPrincipalName</td>
                <td>@d.EnrolledDateTime.ToLocalTime().ToString("g")</td>
                <td>@d.LastSyncDateTime?.ToLocalTime().ToString("g")</td>
                <td>
                    <div class="app-progress">
                        <span>@d.InstalledApps / @d.TotalRequiredApps</span>
                        <div class="progress-bar">
                            <div class="progress-fill @(d.IsFullyEnrolled ? "ready" : "installing")"
                                 style="width: @(d.TotalRequiredApps > 0 ? (d.InstalledApps * 100 / d.TotalRequiredApps) : 0)%">
                            </div>
                        </div>
                    </div>
                </td>
                <td class="status @(d.IsFullyEnrolled ? "ready" : "installing")">
                    @d.StatusLabel
                </td>
                <td>
                    <a href="/device/@d.DeviceId">Details</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}

</SubscriptionGate>

@code {
    private List<DeviceEnrollment>? devices;
    private HubConnection? hub;

    protected override async Task OnInitializedAsync()
    {
        hub = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/enrollmenthub"))
            .Build();

        hub.On<List<DeviceEnrollment>>("DevicesUpdated", updated =>
        {
            devices = updated;
            InvokeAsync(StateHasChanged);
        });

        await hub.StartAsync();
    }

    public async ValueTask DisposeAsync()
    {
        if (hub is not null)
            await hub.DisposeAsync();
    }
}
